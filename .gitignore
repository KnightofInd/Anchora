# =============================================================================
# Anchora — Root .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# SECRETS & CREDENTIALS  ← never commit these
# ---------------------------------------------------------------------------
credentials.txt
*.pem
*.key
*.p12
*.pfx

# ---------------------------------------------------------------------------
# ENVIRONMENT FILES
# Keep *.example files — strip the real ones
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
backend/.env
frontend/.env.local
# keep .env.example and .env.local.example

# ---------------------------------------------------------------------------
# PYTHON
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/

# Test & coverage
.pytest_cache/
.tox/
.coverage
coverage.xml
htmlcov/
*.cover
.hypothesis/

# Type checkers & linters
.mypy_cache/
.dmypy.json
.ruff_cache/
# local pyright / pylance config — IDE-specific, not portable
pyrightconfig.json

# Jupyter / IPython
.ipynb_checkpoints

# ---------------------------------------------------------------------------
# NODE / NEXT.JS
# ---------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# Next.js build output
.next/
out/

# Vercel
.vercel

# Turbopack
.turbo

# Dependency debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Misc Next.js / TS
next-env.d.ts

# ---------------------------------------------------------------------------
# DOCKER
# ---------------------------------------------------------------------------
docker-compose.override.yml

# ---------------------------------------------------------------------------
# OS & EDITOR
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# VSCode workspace settings (keep extensions.json if you want)
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json

# JetBrains IDEs
.idea/
*.iml

# Vim / Emacs swap files
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# MISC
# ---------------------------------------------------------------------------
*.bak
*.tmp
*.temp

# Large binary / presentation files that shouldn't be versioned
*.pdf
*.pptx
*.ppt
