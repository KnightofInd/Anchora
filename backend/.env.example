# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=True
SECRET_KEY=your-very-secret-key-change-in-production

# ─── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Get from: Supabase → Project Settings → Database → Connection String (URI)
# Make sure to append ?sslmode=require
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get from: Supabase → Project Settings → API
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=anchora-documents

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro
GEMINI_MODEL_VERSION=1.5-pro-001
PROMPT_VERSION=v1.0.0

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000","https://anchora.vercel.app"]
